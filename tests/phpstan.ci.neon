# PHPStan config file to include paramaters for github CI
includes:
    # base config
    - ../phpstan.neon
    # extra config for php8.1
    - phpstan.81.neon
parameters:
    # Ignored errors that should be specifically address an issue in a specific file
    ignoreErrors:
        -
            identifier: requireOnce.fileNotFound
            reportUnmatched: false
            path: ../src/class/Admin/Widget_Selection.php
